# ─── Lazarus / FPC build artifacts ───────────────────────────────────────────
# Unit output directory (.ppu/.o land here, see UnitOutputDirectory in the .lpi)
lib/
# IDE backup copies
backup/
# Per-user IDE session (not the project: keep the .lpi)
*.lps
# Package / build state files
*.compiled

# Compiled units and objects
*.ppu
*.o
*.or
*.a
*.rst
*.rsj

# Generated project resource (regenerated by lazbuild from the .lpi)
*.res

# Debug symbols
*.dbg

# ─── Binaries ────────────────────────────────────────────────────────────────
# This project builds the executable next to locale/ (project root).
/lazarus_i18n_template
/lazarus_i18n_template.exe
# Generic binary extensions, in case the output path is changed
*.exe
*.dll
*.so
*.dylib

# CI staging directory (GitHub Actions packages binary + locale here)
dist/

# ─── OS / editor cruft ───────────────────────────────────────────────────────
*~
*.bak
*.orig
*.kate-swp
.DS_Store
Thumbs.db

# Kept on purpose: *.lpi *.lpr *.pas *.lfm *.lang
